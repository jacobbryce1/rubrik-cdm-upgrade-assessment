# ==============================================================
# Rubrik CDM Pre-Upgrade Assessment — Configuration
# ==============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ==============================================================


# ==============================================================
# RSC CONNECTION (Required)
# ==============================================================

# RSC instance base URL
RSC_BASE_URL=https://your-org.my.rubrik.com

# Access Token URI — REQUIRED
# Copy the EXACT URL from RSC > Settings > Service Accounts
# Click your service account and copy "Access Token URI"
RSC_ACCESS_TOKEN_URI=https://your-org.my.rubrik.com/api/client_token

# Service Account Client ID
RSC_CLIENT_ID=your-client-id-here

# Service Account Client Secret
# NOTE: Secret is only shown once when created
RSC_CLIENT_SECRET=your-client-secret-here

# Required permissions:
#   - ViewCluster
#   - ViewSLA
#   - ViewInventory
# Optional (enables live upgrade path data):
#   - UPGRADE_CLUSTER


# ==============================================================
# TARGET VERSION (Required)
# ==============================================================

TARGET_CDM_VERSION=9.1.0


# ==============================================================
# CLUSTER FILTERING (Optional)
# ==============================================================

# Comma-separated cluster names or IDs to include
# Leave empty to assess all discovered clusters
INCLUDE_CLUSTERS=

# Comma-separated cluster names or IDs to exclude
EXCLUDE_CLUSTERS=

# Skip disconnected clusters (recommended: true)
SKIP_DISCONNECTED_CLUSTERS=true


# ==============================================================
# PARALLELISM & CONCURRENCY
# ==============================================================

# Clusters assessed simultaneously
# Recommended: 5-10, Maximum: 50
MAX_PARALLEL_CLUSTERS=10

# Clusters enriched simultaneously (Phase 2)
MAX_PARALLEL_ENRICHMENT=20

# Global concurrent API request cap
MAX_CONCURRENT_API_REQUESTS=20


# ==============================================================
# API RESILIENCE
# ==============================================================

# Retry attempts per failed API call
API_MAX_RETRIES=5

# Exponential backoff: delay = base * (factor ^ attempt)
API_BACKOFF_BASE=1.0
API_BACKOFF_MAX=60.0
API_BACKOFF_FACTOR=2.0

# Per-request timeout (seconds)
API_TIMEOUT_SECONDS=60


# ==============================================================
# TOKEN MANAGEMENT
# ==============================================================

# Refresh token this many seconds before expiry
TOKEN_REFRESH_BUFFER_SEC=300


# ==============================================================
# CDM DIRECT API
# ==============================================================

# Enable CDM direct REST API calls to cluster nodes
# Set false if clusters are behind firewalls/NAT
# When false, only RSC-based checks are performed
CDM_DIRECT_ENABLED=true

# Timeout per CDM node connection attempt (seconds)
CDM_DIRECT_TIMEOUT=10

# Number of node IPs to try for CDM authentication
MAX_CDM_AUTH_ATTEMPTS=3


# ==============================================================
# MEMORY MANAGEMENT
# ==============================================================

# Streaming mode writes results to disk incrementally
# Recommended for 50+ clusters
STREAMING_OUTPUT=false


# ==============================================================
# OUTPUT SETTINGS
# ==============================================================

OUTPUT_DIR=./output
LOG_DIR=./logs

# DEBUG, INFO, WARNING, ERROR
# File log is always DEBUG regardless
LOG_LEVEL=INFO

# Available: csv, json, html
REPORT_FORMATS=csv,json,html


# ==============================================================
# SIZING GUIDE
# ==============================================================
#
# Small (1-10 clusters, <1K servers):
#   MAX_PARALLEL_CLUSTERS=5
#   MAX_CONCURRENT_API_REQUESTS=10
#   STREAMING_OUTPUT=false
#   Runtime: 2-5 minutes
#
# Medium (10-50 clusters, 1K-10K servers):
#   MAX_PARALLEL_CLUSTERS=10
#   MAX_CONCURRENT_API_REQUESTS=20
#   STREAMING_OUTPUT=false
#   Runtime: 5-15 minutes
#
# Large (50-100 clusters, 10K-50K servers):
#   MAX_PARALLEL_CLUSTERS=10
#   MAX_CONCURRENT_API_REQUESTS=20
#   STREAMING_OUTPUT=true
#   Runtime: 15-30 minutes
#
# Very Large (100+ clusters, 50K-100K+ servers):
#   MAX_PARALLEL_CLUSTERS=15
#   MAX_CONCURRENT_API_REQUESTS=25
#   STREAMING_OUTPUT=true
#   API_TIMEOUT_SECONDS=90
#   API_MAX_RETRIES=7
#   Runtime: 30-60 minutes
#
# ==============================================================


# ==============================================================
# TROUBLESHOOTING
# ==============================================================
#
# "404 Not Found" on token endpoint:
#   RSC_ACCESS_TOKEN_URI is wrong
#   Go to RSC > Settings > Service Accounts
#   Copy the exact "Access Token URI"
#
# "401 Unauthorized":
#   RSC_CLIENT_ID or RSC_CLIENT_SECRET is wrong
#   Re-copy from RSC Service Account
#
# "403 Forbidden":
#   Service account disabled or lacks permissions
#
# "Connection refused":
#   RSC_BASE_URL is wrong or host unreachable
#   Verify: curl -I https://your-org.my.rubrik.com
#
# "All nodes unreachable":
#   CDM nodes not accessible from this machine
#   Set CDM_DIRECT_ENABLED=false for RSC-only mode
#
# ==============================================================