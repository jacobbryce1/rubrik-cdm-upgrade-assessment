    "upgrade_paths": {
        "5.0": {
            "direct_upgrade_to": ["5.1", "5.2", "5.3"],
            "recommended_intermediate": "5.3",
            "notes": "Must upgrade through 5.3 before 7.0+."
        },
        "5.1": {
            "direct_upgrade_to": ["5.2", "5.3"],
            "recommended_intermediate": "5.3",
            "notes": "Must upgrade through 5.3 before 7.0+."
        },
        "5.2": {
            "direct_upgrade_to": ["5.3", "6.0"],
            "recommended_intermediate": "6.0",
            "notes": "Can go to 6.0 directly."
        },
        "5.3": {
            "direct_upgrade_to": ["6.0", "7.0"],
            "recommended_intermediate": "7.0",
            "notes": "Can jump to 7.0 directly."
        },
        "6.0": {
            "direct_upgrade_to": ["7.0", "8.0"],
            "recommended_intermediate": "7.0",
            "notes": "Can jump to 7.0 or 8.0."
        },
        "7.0": {
            "direct_upgrade_to": ["8.0", "8.1", "9.0"],
            "recommended_intermediate": "8.1",
            "notes": "Can go to 8.x or 9.0 directly."
        },
        "8.0": {
            "direct_upgrade_to": ["8.1", "9.0", "9.1"],
            "recommended_intermediate": "9.0",
            "notes": "Can go to 8.1 or 9.x directly."
        },
        "8.1": {
            "direct_upgrade_to": ["9.0", "9.1", "9.2"],
            "recommended_intermediate": "9.1",
            "notes": "Can jump to 9.x directly."
        },
        "9.0": {
            "direct_upgrade_to": ["9.1", "9.2", "9.3", "9.4", "9.5"],
            "recommended_intermediate": null,
            "notes": "Direct upgrade within 9.x supported."
        },
        "9.1": {
            "direct_upgrade_to": ["9.2", "9.3", "9.4", "9.5"],
            "recommended_intermediate": null,
            "notes": "Direct upgrade within 9.x supported."
        },
        "9.2": {
            "direct_upgrade_to": ["9.3", "9.4", "9.5"],
            "recommended_intermediate": null,
            "notes": "Direct upgrade within 9.x supported."
        },
        "9.3": {
            "direct_upgrade_to": ["9.4", "9.5"],
